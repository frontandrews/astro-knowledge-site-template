PUBLIC_SITE_NAME=Site Template
PUBLIC_SITE_DESCRIPTION=Reusable editorial site shell for articles, tracks, topics, and reference content.
PUBLIC_SITE_URL=https://example.com
PUBLIC_STORAGE_NAMESPACE=site-template

# Optional practice app base URL. Defaults to /app when unset.
PUBLIC_APP_URL=/app

# Optional legal and support overrides.
PUBLIC_LEGAL_OWNER_NAME=
PUBLIC_LEGAL_OWNER_LOCATION=
PUBLIC_GOVERNING_LAW=
PUBLIC_GOVERNING_VENUE=
PUBLIC_LEGAL_EMAIL=
PUBLIC_SUPPORT_EMAIL=

# Optional strict build guard. When set to 1, the build fails if operator identity
# is still missing, or if optional integrations are configured without legal/support contact.
SITE_ENFORCE_PUBLISH_READINESS=0

# Optional newsletter integration. Only used when the feature is enabled in brand config.
PUBLIC_NEWSLETTER_URL=

# Optional provider-agnostic observability script injection.
# Example:
# PUBLIC_OBSERVABILITY_SCRIPT_SRC=https://analytics.example.com/script.js
# PUBLIC_OBSERVABILITY_SCRIPT_DATA_JSON={"data-domain":"site.example.com"}
PUBLIC_OBSERVABILITY_SCRIPT_SRC=
PUBLIC_OBSERVABILITY_SCRIPT_DATA_JSON=

# Optional CSP extensions for extra third-party origins.
# Use space-separated values, for example:
# PUBLIC_CSP_SCRIPT_SRC=https://analytics.example.com
# PUBLIC_CSP_CONNECT_SRC=https://analytics.example.com https://api.example.com
PUBLIC_CSP_SCRIPT_SRC=
PUBLIC_CSP_STYLE_SRC=
PUBLIC_CSP_FONT_SRC=
PUBLIC_CSP_IMG_SRC=
PUBLIC_CSP_CONNECT_SRC=
PUBLIC_CSP_FRAME_SRC=
PUBLIC_CSP_FORM_ACTION=
PUBLIC_CSP_WORKER_SRC=

# Optional Giscus integration. Comments render only when the feature is enabled in brand config
# and the required values below are present.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# Optional Giscus fine-tuning.
PUBLIC_GISCUS_THEME=app
PUBLIC_GISCUS_EMIT_METADATA=0
PUBLIC_GISCUS_INPUT_POSITION=bottom
PUBLIC_GISCUS_MAPPING=pathname
PUBLIC_GISCUS_REACTIONS_ENABLED=1
PUBLIC_GISCUS_STRICT=0
