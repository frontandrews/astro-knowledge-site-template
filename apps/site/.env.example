# Optional: point guide-site CTAs back to the app during local development.
PUBLIC_APP_URL=http://localhost:4510

# Optional: submit the newsletter form to an external provider endpoint or hosted signup form.
PUBLIC_NEWSLETTER_URL=

# Public contact emails shown on the legal pages.
PUBLIC_LEGAL_EMAIL=contact@seniorpath.pro
PUBLIC_SUPPORT_EMAIL=support@seniorpath.pro

# Optional: enable Giscus comments on guide posts.
PUBLIC_GISCUS_REPO=frontandrews/seniorpath
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=
PUBLIC_GISCUS_THEME=https://seniorpath.pro/giscus-theme.css?v=1
