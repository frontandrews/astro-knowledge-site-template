---
import { getCollection } from 'astro:content'

import TracksPage from '@/components/TracksPage.astro'
import { resolveEditorialRoadmaps } from '@/lib/editorial-roadmaps'

const guides = await getCollection('guides')
const roadmaps = resolveEditorialRoadmaps('en', guides)
---

<TracksPage locale="en" roadmaps={roadmaps} />
