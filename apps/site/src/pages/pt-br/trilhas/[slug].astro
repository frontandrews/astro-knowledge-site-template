---
import { getCollection } from 'astro:content'

import TrackPage from '@/components/TrackPage.astro'
import { resolveEditorialRoadmaps } from '@/lib/editorial-roadmaps'

export async function getStaticPaths() {
  const guides = await getCollection('guides')
  const roadmaps = resolveEditorialRoadmaps('pt-br', guides)

  return roadmaps.map((roadmap) => ({
    params: { slug: roadmap.slug },
    props: { roadmap },
  }))
}

const { roadmap } = Astro.props
---

<TrackPage locale="pt-br" roadmap={roadmap} />
