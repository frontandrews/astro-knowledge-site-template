---
import { getCollection } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { formatEditorialDate } from '@/lib/format-date'
import { getGuideHrefFromEntry, getGuideIndexHref } from '@/lib/guide-links'
import { sortGuidesByRecency } from '@/lib/guide-tree'
import { getSiteCopy } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import { getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedGuideTopics } from '@/lib/topic-taxonomy'

const posts = sortGuidesByRecency((await getCollection('guides')).filter(
  (post) => post.data.status !== 'archived' && post.data.locale === 'pt-br',
))
const copy = getSiteCopy('pt-br')
const items = posts.map((post) => {
  const topics = getLocalizedGuideTopics(post)

  return {
    badgeLabel: post.data.kind === 'article' ? 'Artigo' : undefined,
    completionId: post.data.kind === 'guide' ? post.data.guideId : undefined,
    contentKind: post.data.kind,
    ctaLabel: 'Ler mais',
    description: post.data.description,
    eyebrow: formatEditorialDate(post.data.pubDate, 'pt-BR'),
    href: getGuideHrefFromEntry(post),
    tags: topics.map(({ id, label }) => ({ id, label })),
    title: post.data.title,
  }
})
---

<BaseLayout
  description="Browse the Path to Senior: structured learn-first guides for deeper understanding, stronger interviews, and better engineering judgment."
  englishHref={getGuideIndexHref('en')}
  title={copy.guideIndex.title}
>
  <PageHeader className="px-4 md:px-[1.1rem]" description={copy.guideIndex.copy} title={copy.guideIndex.title} />

  <CompactSection>
    <FilterableDirectory
      allItemsLabel={copy.guideIndex.allItems}
      articleItemsLabel={copy.guideIndex.articleItems}
      completionStorageKey={siteStorageKeys.completedGuides}
      filterLabel={copy.guideIndex.filterLabel}
      fewerFiltersLabel="Mostrar menos"
      guideItemsLabel={copy.guideIndex.guideItems}
      items={items}
      client:load
      kind="guide-rows"
      moreFiltersHref={getTopicIndexHref('pt-br')}
      moreFiltersLabel="mais"
    />
  </CompactSection>
</BaseLayout>
