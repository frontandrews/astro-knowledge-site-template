---
import { getCollection } from 'astro:content'

import StartHerePage from '../../components/StartHerePage.astro'
import { resolveEditorialRoadmap } from '../../lib/editorial-roadmaps'

const guides = await getCollection('guides')
const roadmap = resolveEditorialRoadmap('pt-br', guides)

if (!roadmap) {
  throw new Error('Primary editorial roadmap could not be resolved for pt-br.')
}
---

<StartHerePage locale="pt-br" roadmap={roadmap} />
