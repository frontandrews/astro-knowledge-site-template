---
import { getCollection } from 'astro:content'

import ArticleCard from '../../../components/ArticleCard.astro'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { formatEditorialDate } from '../../../lib/format-date'
import { getGuideIndexHref } from '../../../lib/guide-links'
import { getGuideTaxonomy, getLocalizedPillarLabel } from '../../../lib/guide-taxonomy'
import { sortGuides } from '../../../lib/guide-tree'
import { getSiteCopy } from '../../../lib/site-copy'

const posts = sortGuides((await getCollection('guides')).filter(
  (post) => post.data.status !== 'archived' && post.data.locale === 'pt-br',
))
const filterTones = [
  { dark: '#24364f', light: '#dbeafe' },
  { dark: '#2d3358', light: '#dbe4ff' },
  { dark: '#334155', light: '#e2e8f0' },
  { dark: '#1f4556', light: '#e0f2fe' },
  { dark: '#41305a', light: '#ede9fe' },
  { dark: '#274737', light: '#e2f2ea' },
]
const copy = getSiteCopy('pt-br')
const guideCards = posts.map((post) => {
  const { pillar } = getGuideTaxonomy(post)

  return {
    filterId: pillar?.id ?? 'other',
    filterLabel: pillar ? getLocalizedPillarLabel(pillar, 'pt-br') : 'Outros',
    meta: formatEditorialDate(post.data.pubDate, 'pt-BR'),
    post,
  }
})
const filters = [...new Map(guideCards.map((entry) => [entry.filterId, entry.filterLabel])).entries()].map(
  ([id, label]) => ({ id, label }),
)
---

<BaseLayout
  description="Browse the Path to Senior: structured learn-first guides for deeper understanding, stronger interviews, and better engineering judgment."
  englishHref={getGuideIndexHref('en')}
  title={copy.guideIndex.title}
>
  <section class="section section--compact">
    <div class="panel page-toolbar">
      <div class="page-toolbar__intro">
        <h1 class="section-heading section-heading--compact">{copy.guideIndex.title}</h1>
        <p class="page-toolbar__copy">{copy.guideIndex.copy}</p>
      </div>
    </div>

    <div class="tree-controls tree-controls--compact">
      <p class="section-eyebrow">{copy.guideIndex.filterLabel}</p>
      <div class="meta-list">
        {filters.map((filter, index) => {
          const tone = filterTones[index % filterTones.length]

          return (
            <button
              class="guide-filter-chip"
              data-tree-filter={filter.id}
              style={`--chip-accent: ${tone.light}; --chip-accent-dark: ${tone.dark};`}
              type="button"
            >
              <span>{filter.label}</span>
            </button>
          )
        })}
      </div>
    </div>

    <div class="guide-directory-list">
      {guideCards.map(({ filterId, meta, post }) => (
        <ArticleCard
          categoryLabel={filterId}
          className="guide-directory-list__item"
          meta={meta}
          post={post}
          variant="rich"
        />
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const cards = [...document.querySelectorAll('.guide-directory-list [data-guide-post]')]
  const categoryButtons = [...document.querySelectorAll('[data-tree-filter]')]
  let activeCategory = null
  const completedGuides = (() => {
    try {
      return new Set(JSON.parse(window.localStorage.getItem('seniorpath.site.completed-guides.v1') || '[]'))
    } catch {
      return new Set()
    }
  })()

  const syncCompletedPosts = () => {
    document.querySelectorAll('[data-guide-post]').forEach((post) => {
      const id = post.getAttribute('data-guide-post')
      post.classList.toggle('guide-tree__post--complete', Boolean(id && completedGuides.has(id)))
    })
  }

  const applyTreeFilter = () => {
    const hasFilter = Boolean(activeCategory)

    cards.forEach((node) => {
      const label = node.getAttribute('data-guide-card-category')
      const shouldShow = !hasFilter || label === activeCategory
      node.toggleAttribute('hidden', !shouldShow)
    })
  }

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const value = button.getAttribute('data-tree-filter')

      if (!value) {
        return
      }

      activeCategory = activeCategory === value ? null : value
      categoryButtons.forEach((item) => {
        const itemValue = item.getAttribute('data-tree-filter')
        item.classList.toggle('guide-filter-chip--active', itemValue === activeCategory)
      })
      applyTreeFilter()
    })
  })

  syncCompletedPosts()
  applyTreeFilter()
</script>
