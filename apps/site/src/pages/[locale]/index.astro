---
import LocalizedHomePage from '@/components/LocalizedHomePage.astro'
import { getNonDefaultLocales } from '@/lib/locale-config'

export async function getStaticPaths() {
  return getNonDefaultLocales().map((locale) => ({
    params: { locale },
    props: { locale },
  }))
}

const { locale } = Astro.props
---

<LocalizedHomePage locale={locale} />
