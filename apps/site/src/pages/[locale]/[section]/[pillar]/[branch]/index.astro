---
import ArticleBranchPage from '@/components/ArticleBranchPage.astro'
import { getLocalizedArticleBranchPaths } from '@/lib/localized-article-pages'
import { getSectionDisabledResponse } from '@/lib/section-gate'

export async function getStaticPaths() {
  return getLocalizedArticleBranchPaths()
}

const { branch, locale, pillar, posts } = Astro.props
const disabledResponse = getSectionDisabledResponse('articles')

if (disabledResponse) {
  return disabledResponse
}
---

<ArticleBranchPage branch={branch} locale={locale} pillar={pillar} posts={posts} />
