---
import type { CollectionEntry } from 'astro:content'

import ArticlePage from '@/components/ArticlePage.astro'
import ArticleTranslationComingSoonPage from '@/components/ArticleTranslationComingSoonPage.astro'
import { getLocalizedArticleCanonicalPaths } from '@/lib/localized-article-pages'
import { getSectionDisabledResponse } from '@/lib/section-gate'

export async function getStaticPaths() {
  return getLocalizedArticleCanonicalPaths()
}

type Props = {
  comingSoonPost?: CollectionEntry<'articles'>
  locale: string
  post?: CollectionEntry<'articles'>
}

const { comingSoonPost, locale, post } = Astro.props as Props
const disabledResponse = getSectionDisabledResponse('articles')

if (disabledResponse) {
  return disabledResponse
}
---

{post ? <ArticlePage post={post} /> : null}
{!post && comingSoonPost ? <ArticleTranslationComingSoonPage locale={locale} sourcePost={comingSoonPost} /> : null}
