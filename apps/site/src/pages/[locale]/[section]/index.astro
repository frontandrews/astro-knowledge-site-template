---
import ArticlesIndexPage from '@/components/ArticlesIndexPage.astro'
import ChallengeIndexPage from '@/components/ChallengeIndexPage.astro'
import ConceptsIndexPage from '@/components/ConceptsIndexPage.astro'
import GlossaryIndexPage from '@/components/GlossaryIndexPage.astro'
import TopicIndexPage from '@/components/TopicIndexPage.astro'
import TracksPage from '@/components/TracksPage.astro'
import { getDynamicSectionIndexPaths } from '@/lib/dynamic-section-pages'
import { getNonDefaultLocales } from '@/lib/locale-config'
import { getLocalizedArticleIndexPaths } from '@/lib/localized-article-pages'

export async function getStaticPaths() {
  const localizedSectionPaths = await Promise.all(
    getNonDefaultLocales().map((locale) => getDynamicSectionIndexPaths(locale)),
  )

  return [...getLocalizedArticleIndexPaths(), ...localizedSectionPaths.flat()]
}

const { challenges = [], concepts = [], locale, pageType, posts = [], roadmaps = [], terms = [] } = Astro.props

if (!pageType) {
  return new Response(null, {
    status: 404,
    statusText: 'Not Found',
  })
}
---

{pageType === 'articles' ? <ArticlesIndexPage locale={locale} /> : null}
{pageType === 'tracks' ? <TracksPage locale={locale} roadmaps={roadmaps} /> : null}
{pageType === 'topics' ? <TopicIndexPage locale={locale} posts={posts} /> : null}
{pageType === 'concepts' ? <ConceptsIndexPage concepts={concepts} locale={locale} /> : null}
{pageType === 'glossary' ? <GlossaryIndexPage locale={locale} terms={terms} /> : null}
{pageType === 'challenges' ? <ChallengeIndexPage challenges={challenges} locale={locale} /> : null}
