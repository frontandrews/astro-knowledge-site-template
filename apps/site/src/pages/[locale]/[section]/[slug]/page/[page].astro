---
import TopicGroupPage from '@/components/TopicGroupPage.astro'
import { getLocalizedPaginatedTopicGroupPaths } from '@/lib/paginated-section-pages'

export async function getStaticPaths() {
  return getLocalizedPaginatedTopicGroupPaths()
}

const { groupId, locale, pageType, page } = Astro.props

if (pageType !== 'topics' || !groupId) {
  return new Response(null, {
    status: 404,
    statusText: 'Not Found',
  })
}
---

<TopicGroupPage groupId={groupId} locale={locale} page={page} />
