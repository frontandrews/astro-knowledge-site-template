---
import { getCollection } from 'astro:content'

import ArticleCard from '../components/ArticleCard.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAppHref } from '../lib/app-links'

const posts = (await getCollection('blog')).sort(
  (left, right) => right.data.pubDate.getTime() - left.data.pubDate.getTime(),
)
const featuredPosts = posts.slice(0, 3)
const topics = [...new Set(posts.map((post) => post.data.topic).filter(Boolean))]
---

<BaseLayout
  description="Short guides and checklists that you can read first, then turn into focused practice inside Prepdeck."
  title="Guides"
>
  <section class="hero">
    <div class="hero__grid">
      <div>
        <div class="hero__badges">
          <span class="badge badge--accent">Read first</span>
          <span class="badge">Practice next</span>
          <span class="badge">{posts.length} guides</span>
        </div>
        <h1>Short guides that turn into practice fast.</h1>
        <p>
          Prepdeck works best when reading and practice stay connected. Start with a clear
          guide, grab the checklist, then open the matching deck when you want to rehearse
          the concept instead of just reading about it.
        </p>
        <div class="meta-list">
          <a class="button-link button-link--primary" href="/blog">Browse guides</a>
          <a class="button-link" href={getAppHref('/')}>Open practice</a>
        </div>
      </div>

      <div class="panel">
        <p class="section-eyebrow">How to use it</p>
        <ul class="article-prose compact-list">
          <li>Pick one guide and read the summary first.</li>
          <li>Use the checklist to shape how you explain the topic.</li>
          <li>Open the related deck and practice the answer while it is still fresh.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-heading">Browse by topic</h2>
    <p class="section-copy">
      Start from the area you want to sharpen, then move straight into practice.
    </p>
    <div class="meta-list">
      {topics.map((topic) => (
        <span class="badge">{topic}</span>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-heading">Start with these guides</h2>
    <p class="section-copy">
      Summary-first reading paths that already connect to the practice app.
    </p>
    <div class="panel-grid panel-grid--articles">
      {featuredPosts.map((post) => (
        <ArticleCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
