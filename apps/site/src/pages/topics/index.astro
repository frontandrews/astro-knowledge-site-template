---
import { getCollection } from 'astro:content'

import TopicIndexPage from '@/components/TopicIndexPage.astro'
import { getAvailableTopicGroups } from '@/lib/topic-taxonomy'

const posts = await getCollection('guides')
const groups = getAvailableTopicGroups(posts, 'en').map((group) => ({
  count: 0,
  groupId: group.id,
}))
---

<TopicIndexPage groups={groups} locale="en" />
