---
import { getCollection } from 'astro:content'

import ConceptsIndexPage from '@/components/ConceptsIndexPage.astro'
import { getConceptsHref } from '@/lib/concepts-links'
import { getAvailableConceptDomains, getConceptDomainRouteSegment } from '@/lib/concept-taxonomy'

const concepts = await getCollection('concepts')
const activeConcepts = concepts.filter((concept) => concept.data.locale === 'en' && concept.data.status !== 'archived')
const domains = getAvailableConceptDomains(concepts, 'en').map((domain) => ({
  count: activeConcepts.filter((concept) => concept.data.domainId === domain.id).length,
  domainId: domain.id,
  href: getConceptsHref('en', getConceptDomainRouteSegment(domain.id, 'en')),
}))
---

<ConceptsIndexPage domains={domains} locale="en" />
