---
import { getCollection } from 'astro:content'
import { PATH_TO_SENIOR_PILLARS } from '@prepdeck/content'

import GuideMapCard from '../components/GuideMapCard.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { buildGuideMap } from '../lib/guide-map'

const posts = (await getCollection('guides')).filter(
  (post) => post.data.status !== 'archived' && post.data.locale === 'en',
)
const sections = buildGuideMap(posts)
---

<BaseLayout
  description="See how ideas connect across the Path to Senior."
  title="Learning Map"
>
  <section class="section section--compact">
    <div class="panel page-toolbar">
      <div class="page-toolbar__intro">
        <h1 class="section-heading section-heading--compact">Map</h1>
        <p class="page-toolbar__copy">See how concepts connect across the path.</p>
      </div>
    </div>
  </section>

  {sections.length > 0 ? sections.map((section) => (
    <section class="section section--compact">
      <div class="section-header">
        <div>
          <h2 class="section-heading section-heading--compact">{section.label}</h2>
        </div>
      </div>

      <div class="panel-grid panel-grid--map">
        {section.items.map((item) => (
          <GuideMapCard item={item} />
        ))}
      </div>
    </section>
  )) : (
    <section class="section section--compact">
      <div class="panel empty-state-panel">
        <h2 class="section-heading section-heading--compact">No active map yet.</h2>
        <p class="section-copy">The guide graph will come back as the new Path to Senior content goes live.</p>
        <ul class="planned-pillar-list">
          {PATH_TO_SENIOR_PILLARS.map((pillar) => (
            <li>
              <strong>{pillar.order}. {pillar.title}</strong>
              <span>{pillar.summary}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</BaseLayout>
