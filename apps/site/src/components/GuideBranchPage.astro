---
import type { CollectionEntry } from 'astro:content'
import type { PathBranch, PathPillar } from '@seniorpath/content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import { getGuideBranchHref, getGuideHrefFromEntry } from '@/lib/guide-links'
import { formatEditorialDate } from '@/lib/format-date'
import { getBranchBreadcrumb, getLocalizedBranchLabel, getLocalizedPillarLabel } from '@/lib/guide-taxonomy'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  branch: PathBranch
  locale: SiteLocale
  pillar: PathPillar
  posts: CollectionEntry<'guides'>[]
}

const { branch, locale, pillar, posts } = Astro.props
const copy = getSiteCopy(locale)
const title = getLocalizedBranchLabel(branch, locale)
const pillarLabel = getLocalizedPillarLabel(pillar, locale)
const englishHref = getGuideBranchHref(pillar.id, branch.id, 'en')
const portugueseHref = getGuideBranchHref(pillar.id, branch.id, 'pt-br')
const description =
  posts[0]?.data.description ??
  (locale === 'pt-br'
    ? `Artigos de ${title} dentro de ${pillarLabel}.`
    : `Articles about ${title} inside ${pillarLabel}.`)
const breadcrumbItems = getBranchBreadcrumb(pillar, branch, locale)
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const items = posts.map((post) => ({
  badgeLabel: post.data.kind === 'article' ? copy.directory.noteBadge : undefined,
  completedCtaLabel: copy.directory.readAgain,
  completionId: post.data.guideId,
  contentKind: post.data.kind,
  ctaLabel: copy.directory.readMore,
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getGuideHrefFromEntry(post),
  tags: [],
  title: post.data.title,
}))
---

<BaseLayout
  description={description}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={title}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={description} title={title} />

  <CompactSection>
    <FilterableDirectory
      allItemsLabel={copy.directory.allItems}
      articleItemsLabel={copy.directory.articleItems}
      completionStorageKey={siteStorageKeys.completedGuides}
      fewerFiltersLabel={copy.directory.showLess}
      guideItemsLabel={copy.directory.guideItems}
      items={items}
      kind="guide-rows"
      moreFiltersLabel={copy.directory.more}
      client:load
    />
  </CompactSection>
</BaseLayout>
