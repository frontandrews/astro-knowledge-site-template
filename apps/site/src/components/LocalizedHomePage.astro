---

import ArticlesIndexPage from '@/components/ArticlesIndexPage.astro'
import ChallengeIndexPage from '@/components/ChallengeIndexPage.astro'
import ConceptsIndexPage from '@/components/ConceptsIndexPage.astro'
import GlossaryIndexPage from '@/components/GlossaryIndexPage.astro'
import HomeLandingPage from '@/components/HomeLandingPage.astro'
import TopicIndexPage from '@/components/TopicIndexPage.astro'
import TracksPage from '@/components/TracksPage.astro'
import { HOME_DIRECTORY_PREVIEW_SIZE } from '@/lib/directory'
import {
  RECENT_UPDATES_PREVIEW_SIZE,
  resolveRecentUpdateItems,
} from '@/lib/recent-updates'
import {
  resolveEditorialRoadmaps,
  type EditorialLocale,
  type ResolvedEditorialRoadmap,
} from '@/lib/roadmaps'
import { getSection } from '@/lib/section-manifest'
import {
  getHomeDefaultSection,
} from '@/lib/site-config'
import {
  getActiveChallengesByLocale,
  getActiveConceptsByLocale,
  getActiveGlossaryByLocale,
  getArticleCollection,
} from '@/lib/site-content'
import type { SiteLocale } from '@/lib/site-copy'
import type { CollectionEntry } from 'astro:content'

type Props = {
  locale: SiteLocale
}

const { locale } = Astro.props
const homeSectionId = getHomeDefaultSection()
const homeSection = homeSectionId === 'landing' ? null : getSection(homeSectionId)
const recentUpdates = await resolveRecentUpdateItems(locale, RECENT_UPDATES_PREVIEW_SIZE)

let roadmaps: ResolvedEditorialRoadmap[] = []
let activeConcepts: CollectionEntry<'concepts'>[] = []
let activeChallenges: CollectionEntry<'challenges'>[] = []
let activeGlossary: CollectionEntry<'glossary'>[] = []

if (homeSection?.pageType === 'tracks') {
  const articles = await getArticleCollection()
  roadmaps = resolveEditorialRoadmaps(locale as EditorialLocale, articles)
} else if (homeSection?.pageType === 'concepts') {
  activeConcepts = await getActiveConceptsByLocale(locale)
} else if (homeSection?.pageType === 'glossary') {
  activeGlossary = await getActiveGlossaryByLocale(locale)
} else if (homeSection?.pageType === 'challenges') {
  activeChallenges = await getActiveChallengesByLocale(locale)
}
---

{homeSection?.pageType === 'tracks' ? (
  <TracksPage isHome locale={locale} recentUpdates={recentUpdates} roadmaps={roadmaps} />
) : homeSection?.pageType === 'topics' ? (
  <TopicIndexPage
    isHome
    locale={locale}
    previewCount={HOME_DIRECTORY_PREVIEW_SIZE}
    recentUpdates={recentUpdates}
  />
) : homeSection?.pageType === 'concepts' ? (
  <ConceptsIndexPage concepts={activeConcepts} isHome locale={locale} recentUpdates={recentUpdates} />
) : homeSection?.pageType === 'glossary' ? (
  <GlossaryIndexPage isHome locale={locale} recentUpdates={recentUpdates} terms={activeGlossary} />
) : homeSection?.pageType === 'challenges' ? (
  <ChallengeIndexPage challenges={activeChallenges} isHome locale={locale} recentUpdates={recentUpdates} />
) : homeSectionId === 'landing' ? (
  <HomeLandingPage locale={locale} recentUpdates={recentUpdates} />
) : (
  <ArticlesIndexPage isHome locale={locale} recentUpdates={recentUpdates} />
)}
