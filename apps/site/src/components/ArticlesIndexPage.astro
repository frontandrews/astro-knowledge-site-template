---
import { getCollection } from 'astro:content'
import NewspaperIcon from '@lucide/astro/icons/newspaper'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { formatEditorialDate } from '@/lib/format-date'
import { getGuideHrefFromEntry, getGuideIndexHref } from '@/lib/guide-links'
import { sortGuidesByRecency } from '@/lib/guide-tree'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import { getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedGuideTopics, getOrderedAvailableTopicFilters } from '@/lib/topic-taxonomy'

type Props = {
  locale: SiteLocale
}

const { locale } = Astro.props
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const posts = sortGuidesByRecency((await getCollection('guides')).filter(
  (post) => post.data.status !== 'archived' && post.data.locale === locale,
))
const copy = getSiteCopy(locale)
const availableTopicFilters = getOrderedAvailableTopicFilters(posts, locale)
const items = posts.map((post) => {
  const topics = getLocalizedGuideTopics(post)

  return {
    badgeLabel: post.data.kind === 'article' ? copy.directory.noteBadge : undefined,
    completedCtaLabel: copy.directory.readAgain,
    completionId: post.data.guideId,
    contentKind: post.data.kind,
    ctaLabel: copy.directory.readMore,
    description: post.data.description,
    eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
    href: getGuideHrefFromEntry(post),
    tags: topics.map(({ id, label }) => ({ id, label })),
    title: post.data.title,
  }
})
---

<BaseLayout
  description={copy.articlesIndex.copy}
  englishHref={locale === 'pt-br' ? getGuideIndexHref('en') : undefined}
  portugueseHref={locale === 'en' ? getGuideIndexHref('pt-br') : undefined}
  title={copy.articlesIndex.title}
>
  <PageHeader
    className={locale === 'pt-br' ? 'px-4 md:px-[1.1rem]' : ''}
    description={copy.articlesIndex.copy}
    icon={NewspaperIcon}
    iconLabel={copy.layout.articles}
    title={copy.articlesIndex.title}
  />

  <CompactSection>
    <FilterableDirectory
      allItemsLabel={copy.articlesIndex.allItems}
      articleItemsLabel={copy.articlesIndex.articleItems}
      availableFilters={availableTopicFilters}
      completionStorageKey={siteStorageKeys.completedGuides}
      filterLabel={copy.articlesIndex.filterLabel}
      fewerFiltersLabel={copy.directory.showLess}
      guideItemsLabel={copy.articlesIndex.guideItems}
      items={items}
      client:load
      kind="guide-rows"
      moreFiltersHref={getTopicIndexHref(locale)}
      moreFiltersLabel={copy.directory.more}
    />
  </CompactSection>
</BaseLayout>
