---
import type { CollectionEntry } from 'astro:content'
import PuzzleIcon from '@lucide/astro/icons/puzzle'

import DirectoryList from '@/components/ui/DirectoryList.astro'
import DirectoryPagination from '@/components/ui/DirectoryPagination.astro'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import InfoPanel from '@/components/ui/InfoPanel.astro'
import RouteFilterNav from '@/components/ui/RouteFilterNav.astro'
import { ARTICLE_DIRECTORY_PAGE_SIZE, paginateItems } from '@/lib/directory'
import { getChallengeLevelLabel, sortChallenges } from '@/lib/challenge-meta'
import {
  getChallengeHrefFromEntry,
  getChallengeIndexHref,
  getChallengeIndexPageHref,
  getChallengeTagHref,
  getChallengeTagPageHref,
} from '@/lib/challenge-links'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import type { RecentUpdateItem } from '@/lib/recent-updates'
import { getRouteFilterEntries, getRouteFilterEntryById } from '@/lib/route-filters'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  challenges: CollectionEntry<'challenges'>[]
  isHome?: boolean
  locale: SiteLocale
  page?: number
  recentUpdates?: RecentUpdateItem[]
  selectedFilterId?: string | null
}

const {
  challenges,
  isHome = false,
  locale,
  page = 1,
  recentUpdates = [],
  selectedFilterId = null,
} = Astro.props
const copy = getSiteCopy(locale)
const description = getPageTypeDescription('challenges', locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getChallengeIndexHref(supportedLocale),
)
const sortedChallenges = sortChallenges(challenges)
const levelFilters = ['beginner', 'intermediate', 'advanced']
  .filter((level) => sortedChallenges.some((challenge) => challenge.data.level === level))
  .map((level) => ({
    id: `level:${level}`,
    label: getChallengeLevelLabel(level as 'beginner' | 'intermediate' | 'advanced', locale),
  }))
const typeFilters = Array.from(
  new Map(
    sortedChallenges.map((challenge) => [
      challenge.data.type,
      {
        id: `type:${challenge.data.type}`,
        label: challenge.data.typeLabel,
      },
    ]),
  ).values(),
)
const availableFilters = [...levelFilters, ...typeFilters]
const items = sortedChallenges.map((challenge) => {
  const levelLabel = getChallengeLevelLabel(challenge.data.level, locale)

  return {
    ctaLabel: copy.challenge.readChallenge,
    description: challenge.data.description,
    eyebrow: `${challenge.data.typeLabel} • ${levelLabel} • ${challenge.data.estimatedMinutes} min`,
    href: getChallengeHrefFromEntry(challenge),
    tags: [
      {
        id: `level:${challenge.data.level}`,
        label: levelLabel,
      },
      {
        id: `type:${challenge.data.type}`,
        label: challenge.data.typeLabel,
      },
    ],
    title: challenge.data.title,
  }
})
const filterEntries = getRouteFilterEntries(availableFilters, locale)
const selectedFilter = selectedFilterId
  ? getRouteFilterEntryById(availableFilters, locale, selectedFilterId)
  : null
const filteredItems = selectedFilter
  ? items.filter((item) => item.tags.some((tag) => tag.id === selectedFilter.id))
  : items
const paginatedItems = paginateItems(filteredItems, page, ARTICLE_DIRECTORY_PAGE_SIZE)
const title = page > 1
  ? `${selectedFilter ? `${getPageTypeLabel('challenges', locale)} · ${selectedFilter.label}` : getPageTypeLabel('challenges', locale)} · ${copy.directory.page} ${paginatedItems.currentPage}`
  : selectedFilter ? `${getPageTypeLabel('challenges', locale)} · ${selectedFilter.label}` : getPageTypeLabel('challenges', locale)
const isPaginatedArchivePage = paginatedItems.currentPage > 1
---

<DirectoryIndexShell
  description={description}
  icon={PuzzleIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  noindex={isPaginatedArchivePage}
  pagefind={!isPaginatedArchivePage}
  recentUpdates={isHome ? recentUpdates : []}
  recentUpdatesLocale={isHome ? locale : undefined}
  title={title}
>
  {paginatedItems.items.length > 0 ? (
    <>
      <RouteFilterNav
        activeFilterId={selectedFilter?.id}
        allHref={getChallengeIndexHref(locale)}
        allLabel={copy.challengeIndex.allItems}
        entries={filterEntries}
        filterLabel={copy.challengeIndex.filterLabel}
        getHref={(tagSlug) => getChallengeTagHref(locale, tagSlug)}
      />
      <DirectoryList items={paginatedItems.items} layout="rows" />
    </>
  ) : (
    <InfoPanel body={copy.challengeIndex.emptyState} />
  )}

  <DirectoryPagination
    currentPage={paginatedItems.currentPage}
    getHref={(targetPage) =>
      selectedFilter
        ? getChallengeTagPageHref(locale, selectedFilter.slug, targetPage)
        : getChallengeIndexPageHref(locale, targetPage)}
    nextLabel={copy.directory.nextPage}
    pageCount={paginatedItems.pageCount}
    pageLabel={copy.directory.page}
    previousLabel={copy.directory.previousPage}
  />
</DirectoryIndexShell>
