---
import type { CollectionEntry } from 'astro:content'
import TagsIcon from '@lucide/astro/icons/tags'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { formatEditorialDate } from '@/lib/format-date'
import { getGuideHrefFromEntry } from '@/lib/guide-links'
import { sortGuidesByRecency } from '@/lib/guide-tree'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import { getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedGuideTopics, getOrderedAvailableTopicFilters } from '@/lib/topic-taxonomy'

type Props = {
  locale: SiteLocale
  posts: CollectionEntry<'guides'>[]
}

const { locale, posts } = Astro.props
const copy = getSiteCopy(locale)
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const sortedPosts = sortGuidesByRecency(posts)
const availableFilters = getOrderedAvailableTopicFilters(sortedPosts, locale)
const items = sortedPosts.map((post) => ({
  badgeLabel: post.data.kind === 'article' ? copy.directory.noteBadge : undefined,
  completedCtaLabel: copy.directory.readAgain,
  completionId: post.data.guideId,
  contentKind: post.data.kind,
  ctaLabel: copy.directory.readMore,
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getGuideHrefFromEntry(post),
  tags: getLocalizedGuideTopics(post).map(({ id, label }) => ({ id, label })),
  title: post.data.title,
}))
---

<DirectoryIndexShell
  description={copy.topicIndex.copy}
  englishHref={getTopicIndexHref('en')}
  icon={TagsIcon}
  iconLabel={copy.topicIndex.title}
  portugueseHref={getTopicIndexHref('pt-br')}
  title={copy.topicIndex.title}
>
  <FilterableDirectory
    allItemsLabel={copy.directory.allItems}
    articleItemsLabel={copy.directory.articleItems}
    availableFilters={availableFilters}
    completionStorageKey={siteStorageKeys.completedGuides}
    filterLabel={copy.directory.filterByTopic}
    filterQueryKey="topic"
    guideItemsLabel={copy.directory.guideItems}
    items={items}
    client:load
    kind="guide-rows"
  />
</DirectoryIndexShell>
