---
import type { CollectionEntry } from 'astro:content'
import TagsIcon from '@lucide/astro/icons/tags'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { getArticleHrefFromEntry } from '@/lib/article-links'
import { sortArticlesByRecency } from '@/lib/article-tree'
import { formatEditorialDate } from '@/lib/format-date'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { siteStorageKeys } from '@/lib/storage-keys'
import { getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedArticleTopics, getOrderedAvailableTopicFilters } from '@/lib/topic-taxonomy'

type Props = {
  locale: SiteLocale
  posts: CollectionEntry<'articles'>[]
}

const { locale, posts } = Astro.props
const copy = getSiteCopy(locale)
const title = getPageTypeLabel('topics', locale)
const description = getPageTypeDescription('topics', locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) => getTopicIndexHref(supportedLocale))
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const sortedPosts = sortArticlesByRecency(posts)
const availableFilters = getOrderedAvailableTopicFilters(sortedPosts, locale)
const items = sortedPosts.map((post) => ({
  badgeLabel: post.data.kind === 'note' ? copy.directory.noteBadge : undefined,
  completedCtaLabel: copy.directory.readAgain,
  completionId: post.data.articleId,
  contentKind: post.data.kind,
  ctaLabel: copy.directory.readMore,
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getArticleHrefFromEntry(post),
  tags: getLocalizedArticleTopics(post).map(({ id, label }) => ({ id, label })),
  title: post.data.title,
}))
---

<DirectoryIndexShell
  description={description}
  icon={TagsIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  title={title}
>
  <FilterableDirectory
    allItemsLabel={copy.directory.allItems}
    articleItemsLabel={copy.directory.articleItems}
    availableFilters={availableFilters}
    completionStorageKey={siteStorageKeys.completedArticles}
    filterLabel={copy.directory.filterByTopic}
    filterQueryKey="topic"
    items={items}
    client:load
    layout="rows"
    noteItemsLabel={copy.directory.noteItems}
  />
</DirectoryIndexShell>
