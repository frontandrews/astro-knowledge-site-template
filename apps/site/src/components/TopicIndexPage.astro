---
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import BaseLayout from '@/layouts/BaseLayout.astro'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { getTopicGroupHref, getTopicIndexHref } from '@/lib/topic-links'
import { getLocalizedTopicGroupLabel } from '@/lib/topic-taxonomy'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type TopicGroupWithCount = {
  count: number
  groupId: string
}

type Props = {
  locale: SiteLocale
  groups: TopicGroupWithCount[]
}

const { locale, groups } = Astro.props
const copy = getSiteCopy(locale)
const items = groups.map(({ groupId }) => ({
  href: getTopicGroupHref(groupId, locale),
  tags: [],
  title: getLocalizedTopicGroupLabel(groupId, locale),
}))
---

<BaseLayout
  description={copy.topicIndex.copy}
  englishHref={getTopicIndexHref('en')}
  portugueseHref={getTopicIndexHref('pt-br')}
  title={copy.topicIndex.title}
>
  <PageHeader description={copy.topicIndex.copy} title={copy.topicIndex.title} />

  <CompactSection>
    <FilterableDirectory
      items={items}
      kind="title-cards"
    />
  </CompactSection>
</BaseLayout>
