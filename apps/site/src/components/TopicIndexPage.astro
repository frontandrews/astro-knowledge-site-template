---
import type { CollectionEntry } from 'astro:content'
import TagsIcon from '@lucide/astro/icons/tags'

import DirectoryList from '@/components/ui/DirectoryList.astro'
import DirectoryPagination from '@/components/ui/DirectoryPagination.astro'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import {
  TOPIC_INDEX_PAGE_SIZE,
  buildTopicDirectoryItems,
  paginateItems,
} from '@/lib/directory'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import type { RecentUpdateItem } from '@/lib/recent-updates'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { getActiveArticlesByLocale } from '@/lib/site-content'
import { getTopicIndexHref, getTopicIndexPageHref } from '@/lib/topic-links'
import { ui } from '@/lib/ui'

type Props = {
  isHome?: boolean
  locale: SiteLocale
  page?: number
  posts?: CollectionEntry<'articles'>[]
  previewCount?: number
  recentUpdates?: RecentUpdateItem[]
}

const { isHome = false, locale, page = 1, posts = [], previewCount, recentUpdates = [] } = Astro.props
const copy = getSiteCopy(locale)
const title = getPageTypeLabel('topics', locale)
const description = getPageTypeDescription('topics', locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getTopicIndexHref(supportedLocale),
)
const sourcePosts = posts.length > 0 ? posts : await getActiveArticlesByLocale(locale)
const items = buildTopicDirectoryItems(sourcePosts, locale)
const isPreview = typeof previewCount === 'number'
const paginatedItems = paginateItems(items, page, TOPIC_INDEX_PAGE_SIZE)
const visibleItems = isPreview ? items.slice(0, previewCount) : paginatedItems.items
const pageTitle = !isPreview && page > 1
  ? `${title} · ${copy.directory.page} ${paginatedItems.currentPage}`
  : title
const isPaginatedArchivePage = !isPreview && paginatedItems.currentPage > 1
---

<DirectoryIndexShell
  description={description}
  icon={TagsIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  noindex={isPaginatedArchivePage}
  pagefind={!isPaginatedArchivePage && !isPreview}
  recentUpdates={isHome ? recentUpdates : []}
  recentUpdatesLocale={isHome ? locale : undefined}
  title={pageTitle}
>
  {visibleItems.length > 0 ? (
    <DirectoryList items={visibleItems} layout="cards" />
  ) : (
    <p class={ui.bodyCopy}>{copy.articlesIndex.comingSoon}</p>
  )}

  {isPreview ? (
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a class="inline-flex min-h-11 items-center justify-center rounded-xs border border-site-line bg-site-panel px-4 text-sm font-semibold text-site-ink transition-colors duration-150 hover:bg-site-hover hover:text-site-link-hover focus-visible:bg-site-hover focus-visible:text-site-link-hover focus-visible:outline-none" href={getTopicIndexHref(locale)}>
        {copy.topicIndex.viewAllLabel}
      </a>
    </div>
  ) : (
    <DirectoryPagination
      currentPage={paginatedItems.currentPage}
      getHref={(targetPage) => getTopicIndexPageHref(locale, targetPage)}
      nextLabel={copy.directory.nextPage}
      pageCount={paginatedItems.pageCount}
      pageLabel={copy.directory.page}
      previousLabel={copy.directory.previousPage}
    />
  )}
</DirectoryIndexShell>
