---
import type { ResolvedEditorialRoadmap } from '@/lib/roadmaps'
import RouteIcon from '@lucide/astro/icons/route'

import ArticleCard from '@/components/ArticleCard.astro'
import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import TrackProgressPanel from '@/components/TrackProgressPanel.astro'
import { getArticleReadingTimeMinutes } from '@/lib/article-meta'
import { formatEditorialDate } from '@/lib/format-date'
import { resolveLocaleHrefMap, resolveLocaleMap } from '@/lib/locale-config'
import { getSiteCopy, getSiteDateLocale, type SiteLocale } from '@/lib/site-copy'
import { getTracksHref } from '@/lib/tracks-links'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { ui } from '@/lib/ui'

type Props = {
  locale: SiteLocale
  roadmap: ResolvedEditorialRoadmap
}

const { locale, roadmap } = Astro.props
const copy = getSiteCopy(locale)
const roadmapSlugs = roadmap.slugs as Record<string, string | undefined>
const alternateLocaleHrefs = resolveLocaleMap((supportedLocale) => {
  const localizedSlug = roadmapSlugs[supportedLocale]
  return localizedSlug ? getTracksHref(supportedLocale, localizedSlug) : null
})
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  getTracksHref(supportedLocale, roadmapSlugs[supportedLocale] ?? null)
  ?? getTracksHref(supportedLocale),
)
const tracksHref = getTracksHref(locale) ?? '/'
const dateLocale = getSiteDateLocale(locale)
const shareUrl = Astro.url.href
const trackItems = roadmap.articleNodes.map((node, index) => ({
  articleId: node.articleId,
  href: node.href,
  stepLabel: String(index + 1),
  title: node.post.data.title,
}))
const totalReadingMinutes = roadmap.articleNodes.reduce((sum, node) => sum + getArticleReadingTimeMinutes(node.post), 0)
---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  description={roadmap.summary}
  localeHrefs={localeHrefs}
  title={roadmap.title}
>
  <PageHeader description={roadmap.summary} icon={RouteIcon} iconLabel={copy.layout.tracks} title={roadmap.title} />

  <TrackProgressPanel
    items={trackItems}
    locale={locale}
    tracksHref={tracksHref}
    totalReadingMinutes={totalReadingMinutes}
  />

  <CompactSection className="xl:mt-0">
    <div class={ui.linearList}>
      {roadmap.articleNodes.map((node, index) => (
        <ArticleCard
          className={index === 0 ? 'border-t-0' : ''}
          eyebrow={`${formatEditorialDate(node.post.data.pubDate, dateLocale)} - ${copy.startHere.stepLabel} ${index + 1}`}
          eyebrowVariant="sentence"
          post={node.post}
          subtitle={node.post.data.description}
          variant="linear"
        />
      ))}
    </div>
  </CompactSection>

  <ArticleSharePanel
    description={roadmap.summary}
    locale={locale}
    title={roadmap.title}
    url={shareUrl}
  />
</BaseLayout>
