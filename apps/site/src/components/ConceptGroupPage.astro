---
import type { CollectionEntry } from 'astro:content'

import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { getConceptHrefFromEntry, getConceptsHref } from '@/lib/concepts-links'
import {
  getConceptDomainRouteSegment,
  getConceptGroupRouteSegment,
  getLocalizedConceptDomainLabel,
  getLocalizedConceptGroupLabel,
  getLocalizedConceptGroupSummary,
} from '@/lib/concept-taxonomy'
import type { SiteLocale } from '@/lib/site-copy'

type Props = {
  concepts: CollectionEntry<'concepts'>[]
  domainId: string
  groupId: string
  locale: SiteLocale
}

const { concepts, domainId, groupId, locale } = Astro.props
const domainLabel = getLocalizedConceptDomainLabel(domainId, locale)
const groupLabel = getLocalizedConceptGroupLabel(domainId, groupId, locale)
const groupSummary = getLocalizedConceptGroupSummary(domainId, groupId, locale)
const englishHref = getConceptsHref(
  'en',
  getConceptDomainRouteSegment(domainId, 'en'),
  getConceptGroupRouteSegment(domainId, groupId, 'en'),
)
const portugueseHref = getConceptsHref(
  'pt-br',
  getConceptDomainRouteSegment(domainId, 'pt-br'),
  getConceptGroupRouteSegment(domainId, groupId, 'pt-br'),
)
const breadcrumbItems = [
  {
    href: getConceptsHref(locale),
    label: locale === 'pt-br' ? 'Conceitos' : 'Concepts',
  },
  {
    href: getConceptsHref(locale, getConceptDomainRouteSegment(domainId, locale)),
    label: domainLabel,
  },
  {
    href: null,
    label: groupLabel,
  },
]
const items = concepts.map((concept) => ({
  description: concept.data.description,
  href: getConceptHrefFromEntry(concept),
  tags: [],
  title: concept.data.title,
}))
---

<BaseLayout
  description={groupSummary}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={groupLabel}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={groupSummary} title={groupLabel} />

  <CompactSection>
    <FilterableDirectory
      items={items}
      kind="title-cards"
    />
  </CompactSection>
</BaseLayout>
