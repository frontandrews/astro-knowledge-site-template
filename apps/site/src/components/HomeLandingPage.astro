---
import CompactSection from '@/components/ui/CompactSection.astro'
import LinkCard from '@/components/ui/LinkCard.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import RecentlyUpdatedSection from '@/components/RecentlyUpdatedSection.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import {
  getHomeLandingCopy,
} from '@/lib/site-config'
import {
  getLocalePath,
  resolveLocaleHrefMap,
} from '@/lib/locale-config'
import {
  getEnabledSections,
  getSectionDescription,
  getSectionHref,
  getSectionLabel,
} from '@/lib/section-manifest'
import type { RecentUpdateItem } from '@/lib/recent-updates'
import type { SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type Props = {
  locale: SiteLocale
  recentUpdates?: RecentUpdateItem[]
}

const { locale, recentUpdates = [] } = Astro.props
const landing = getHomeLandingCopy(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) => getLocalePath(supportedLocale))
const sectionCards = getEnabledSections()
  .map((section) => ({
    description: getSectionDescription(section.id, locale),
    href: getSectionHref(section.id, locale),
    title: getSectionLabel(section.id, locale),
  }))
  .filter(
    (
      card,
    ): card is {
      description: string
      href: string
      title: string
    } => Boolean(card.href),
  )
---

<BaseLayout description={landing.description} localeHrefs={localeHrefs} title={landing.title}>
  <PageHeader description={landing.description} title={landing.title}>
    <p class="m-0 text-[0.72rem] font-bold uppercase tracking-[0.18em] text-site-line-strong">
      {landing.eyebrow}
    </p>
  </PageHeader>

  <div data-pagefind-ignore>
    <CompactSection className={ui.cardsGrid}>
      {sectionCards.map((card) => (
        <LinkCard description={card.description} href={card.href} title={card.title} />
      ))}
    </CompactSection>
  </div>

  <div data-pagefind-ignore>
    <RecentlyUpdatedSection items={recentUpdates} locale={locale} />
  </div>
</BaseLayout>
