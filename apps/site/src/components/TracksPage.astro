---
import RouteIcon from '@lucide/astro/icons/route'

import BaseLayout from '@/layouts/BaseLayout.astro'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import type { ResolvedEditorialRoadmap } from '@/lib/roadmaps'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { getTracksHref } from '@/lib/tracks-links'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  isHome?: boolean
  locale: SiteLocale
  roadmaps: ResolvedEditorialRoadmap[]
}

const { isHome = false, locale, roadmaps } = Astro.props
const copy = getSiteCopy(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getTracksHref(supportedLocale),
)
const title = getPageTypeLabel('tracks', locale)
const description = getPageTypeDescription('tracks', locale)
const items = roadmaps.map((roadmap) => ({
  href: roadmap.href,
  tags: roadmap.tags,
  title: roadmap.title,
}))
---

<BaseLayout
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <PageHeader
    description={description}
    icon={RouteIcon}
    iconLabel={title}
    title={title}
  />

  <CompactSection>
    <FilterableDirectory
      filterLabel={copy.tracksIndex.filterLabel}
      fewerFiltersLabel={copy.directory.showLess}
      items={items}
      client:idle
      layout="cards"
      moreFiltersLabel={copy.directory.more}
    />
  </CompactSection>
</BaseLayout>
