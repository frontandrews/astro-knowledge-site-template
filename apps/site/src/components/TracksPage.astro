---
import RouteIcon from '@lucide/astro/icons/route'

import BaseLayout from '@/layouts/BaseLayout.astro'
import type { ResolvedEditorialRoadmap } from '@/lib/editorial-roadmaps'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { getTracksHref } from '@/lib/tracks-links'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'

type Props = {
  locale: SiteLocale
  roadmaps: ResolvedEditorialRoadmap[]
}

const { locale, roadmaps } = Astro.props
const englishHref = getTracksHref('en')
const portugueseHref = getTracksHref('pt-br')
const copy = getSiteCopy(locale)
const items = roadmaps.map((roadmap) => ({
  href: roadmap.href,
  tags: roadmap.tags,
  title: roadmap.title,
}))
---

<BaseLayout
  description={copy.tracksIndex.copy}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={copy.tracksIndex.title}
>
  <PageHeader
    description={copy.tracksIndex.copy}
    icon={RouteIcon}
    iconLabel={copy.tracksIndex.title}
    title={copy.tracksIndex.title}
  />

  <CompactSection>
    <FilterableDirectory
      filterLabel={copy.tracksIndex.filterLabel}
      fewerFiltersLabel={copy.directory.showLess}
      items={items}
      client:load
      kind="title-cards"
      moreFiltersLabel={copy.directory.more}
    />
  </CompactSection>
</BaseLayout>
