---
import SearchIcon from '@lucide/astro/icons/search'
import XIcon from '@lucide/astro/icons/x'

import { cn } from '@/lib/cn'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type Props = {
  locale: SiteLocale
}

const { locale } = Astro.props
const isDev = import.meta.env.DEV
const siteCopy = getSiteCopy(locale)
const copy =
  locale === 'pt-br'
    ? {
        close: 'Fechar busca',
        error: 'A busca não está disponível no momento.',
        empty: 'Digite para buscar em artigos, conceitos, termos e tópicos.',
        hint: 'Busca no site',
        loading: 'Buscando...',
        noResults: 'Nenhum resultado encontrado.',
        placeholder: 'Buscar',
        shortcut: 'Ctrl K',
        title: 'Buscar',
        unavailable: 'A busca só fica disponível em preview/build.',
      }
    : {
        close: 'Close search',
        error: 'Search is currently unavailable.',
        empty: 'Type to search across articles, concepts, glossary terms, and topics.',
        hint: 'Site search',
        loading: 'Searching...',
        noResults: 'No results found.',
        placeholder: 'Search',
        shortcut: 'Ctrl K',
        title: 'Search',
        unavailable: 'Search is only available in preview/build.',
      }
const desktopTriggerClass =
  cn(ui.controlButton, 'hidden nav:inline-flex nav:h-9 nav:w-54 nav:justify-between nav:gap-3 px-3 py-0 text-left text-[0.9rem] text-site-ink-muted lg:h-10 lg:w-60 lg:gap-3.5 lg:text-[0.98rem]')
const mobileTriggerClass =
  cn(ui.controlButton, 'min-h-10 px-3 py-2 lg:min-h-11 nav:hidden')
const searchResultLinkClass = ui.searchResultLink
---

<button
  aria-expanded="false"
  class={desktopTriggerClass}
  data-search-trigger="desktop"
  type="button"
>
  <span class="inline-flex items-center gap-2">
    <SearchIcon aria-hidden="true" class="size-4" />
    <span>{copy.placeholder}</span>
  </span>
  <span class="rounded-xs border border-site-line bg-site-surface px-1.5 py-0.5 text-[0.68rem] uppercase tracking-[0.08em] text-site-ink-muted lg:px-2 lg:py-[0.35rem] lg:text-[0.76rem]">
    {copy.shortcut}
  </span>
</button>

<button
  aria-expanded="false"
  class={mobileTriggerClass}
  data-search-trigger="mobile"
  type="button"
>
  <SearchIcon aria-hidden="true" class="size-4" />
  <span class="sr-only">{copy.title}</span>
</button>

<div class="search-launcher-backdrop fixed inset-0 z-40 hidden overflow-y-auto p-4 md:p-6" data-search-overlay>
  <div class={ui.searchDialog}>
    <div class="flex items-center gap-3 border-b border-site-line px-4 py-3 lg:gap-3.5 lg:px-5 lg:py-3.5">
      <SearchIcon aria-hidden="true" class="size-4 shrink-0 text-site-ink-muted" />
      <input
        class="min-w-0 flex-1 bg-transparent text-[1rem] text-site-ink outline-none placeholder:text-site-ink-muted lg:text-[1.08rem]"
        data-search-input
        placeholder={copy.placeholder}
        type="search"
      />
      <button
        class={cn(mobileTriggerClass, 'nav:inline-flex')}
        data-search-close
        type="button"
      >
        <XIcon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.close}</span>
      </button>
    </div>
    <div class="flex min-h-0 flex-1 flex-col gap-3 px-4 py-4 lg:gap-3.5 lg:px-5 lg:py-5">
      <p class={ui.dialogHint}>{copy.hint}</p>
      <div class="grid min-h-0 flex-1 gap-2 overflow-y-auto pr-1" data-search-results></div>
      <p class="m-0 text-sm text-site-ink-muted lg:text-[0.96rem]" data-search-status>{isDev ? copy.unavailable : copy.empty}</p>
    </div>
  </div>
</div>

<script define:vars={{ copy, isDev, locale, searchResultLinkClass, siteCopy }} is:inline>
  const searchTriggers = [...document.querySelectorAll('[data-search-trigger]')];
  const searchOverlay = document.querySelector('[data-search-overlay]');
  const searchInput = document.querySelector('[data-search-input]');
  const searchClose = document.querySelector('[data-search-close]');
  const searchResults = document.querySelector('[data-search-results]');
  const searchStatus = document.querySelector('[data-search-status]');

  let pagefindModule;
  let searchTimer;

  const groupLabel = (url) => {
    if (url.startsWith('/pt-br/artigos') || url.startsWith('/articles')) return siteCopy.layout.articles;
    if (url.startsWith('/pt-br/conceitos') || url.startsWith('/concepts')) return siteCopy.layout.concepts;
    if (url.startsWith('/pt-br/glossario') || url.startsWith('/glossary')) return siteCopy.layout.glossary;
    if (url.startsWith('/pt-br/topicos') || url.startsWith('/topics')) return siteCopy.layout.topics;
    if (url.startsWith('/pt-br/trilhas') || url.startsWith('/tracks')) return siteCopy.layout.tracks;
    return siteCopy.directory.page;
  };

  const setOpen = (isOpen) => {
    if (!(searchOverlay instanceof HTMLElement)) return;
    searchOverlay.classList.toggle('hidden', !isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
    searchTriggers.forEach((trigger) => trigger.setAttribute('aria-expanded', String(isOpen)));
    if (isOpen && searchInput instanceof HTMLInputElement) {
      queueMicrotask(() => searchInput.focus());
    }
  };

  const renderResults = (results) => {
    if (!(searchResults instanceof HTMLElement)) return;
    searchResults.innerHTML = results
      .map((result) => {
        const excerpt = result.excerpt ?? '';
        return `
          <a class="${searchResultLinkClass}" href="${result.url}">
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-site-ink-muted lg:text-[0.76rem]">${groupLabel(result.url)}</span>
            <span class="text-base font-semibold leading-[1.3] text-site-ink lg:text-[1.08rem]">${result.meta?.title ?? result.url}</span>
            ${excerpt ? `<span class="text-sm leading-6 text-site-ink-soft lg:text-[0.98rem]">${excerpt}</span>` : ''}
          </a>
        `;
      })
      .join('');
  };

  const runSearch = async (term) => {
    if (!(searchStatus instanceof HTMLElement) || !(searchResults instanceof HTMLElement)) return;

    if (isDev) {
      searchResults.innerHTML = '';
      searchStatus.textContent = copy.unavailable;
      return;
    }

    const query = term.trim();
    if (!query) {
      searchResults.innerHTML = '';
      searchStatus.textContent = copy.empty;
      return;
    }

    searchStatus.textContent = copy.loading;

    try {
      pagefindModule ??= await import('/pagefind/pagefind.js');
      const response = await pagefindModule.search(query);
      const results = await Promise.all(
        response.results.slice(0, 8).map(async (result) => {
          const data = await result.data();
          return {
            excerpt: data.excerpt,
            meta: data.meta,
            url: data.url,
          };
        }),
      );

      renderResults(results);
      searchStatus.textContent = results.length ? '' : copy.noResults;
    } catch {
      searchResults.innerHTML = '';
      searchStatus.textContent = copy.error;
    }
  };

  searchTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => setOpen(true));
  });

  searchClose?.addEventListener('click', () => setOpen(false));
  searchOverlay?.addEventListener('click', (event) => {
    if (event.target === searchOverlay) setOpen(false);
  });

  document.addEventListener('keydown', (event) => {
    const target = event.target;
    const isEditable =
      target instanceof HTMLInputElement ||
      target instanceof HTMLTextAreaElement ||
      target instanceof HTMLSelectElement ||
      (target instanceof HTMLElement && target.isContentEditable);

    if (event.key === 'Escape') {
      setOpen(false);
      return;
    }

    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      setOpen(true);
      return;
    }

    if (!isEditable && event.key === '/') {
      event.preventDefault();
      setOpen(true);
    }
  });

  searchInput?.addEventListener('input', (event) => {
    const value =
      event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value : '';

    clearTimeout(searchTimer);
    searchTimer = window.setTimeout(() => {
      runSearch(value);
    }, 120);
  });
</script>
