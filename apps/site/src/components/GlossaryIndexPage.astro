---
import type { CollectionEntry } from 'astro:content'
import BookTextIcon from '@lucide/astro/icons/book-text'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { getGlossaryHrefFromEntry, getGlossaryIndexHref } from '@/lib/glossary-links'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import { translateSiteLabels } from '@/lib/site-labels'
import { getSiteCopy, getSiteDateLocale, type SiteLocale } from '@/lib/site-copy'

type Props = {
  isHome?: boolean
  locale: SiteLocale
  terms: CollectionEntry<'glossary'>[]
}

const { isHome = false, locale, terms } = Astro.props
const copy = getSiteCopy(locale)
const sortLocale = getSiteDateLocale(locale)
const title = getPageTypeLabel('glossary', locale)
const description = getPageTypeDescription('glossary', locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getGlossaryIndexHref(supportedLocale),
)
const sortedTerms = [...terms].sort((left, right) =>
  left.data.title.localeCompare(right.data.title, sortLocale, {
    sensitivity: 'base',
  }),
)
const tagEntries = Array.from(
  new Map(
    sortedTerms
      .flatMap((term) =>
        translateSiteLabels(term.data.tags, locale).map((label, index) => [term.data.tags[index], label] as const),
      )
      .sort((left, right) => left[1].localeCompare(right[1], sortLocale, { sensitivity: 'base' })),
  ).entries(),
).map(([id, label]) => ({ id, label }))
const items = sortedTerms.map((term) => ({
  href: getGlossaryHrefFromEntry(term),
  tags: translateSiteLabels(term.data.tags, locale).map((label, index) => ({
    id: term.data.tags[index],
    label,
  })),
  title: term.data.title,
}))
---

<DirectoryIndexShell
  description={description}
  icon={BookTextIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  title={title}
>
  <FilterableDirectory
    allItemsLabel={copy.directory.allItems}
    availableFilters={tagEntries}
    articleItemsLabel={copy.directory.articleItems}
    filterLabel={copy.directory.filterByTopic}
    filterQueryKey="tag"
    items={items}
    client:idle
    layout="cards"
    noteItemsLabel={copy.directory.noteItems}
  />
</DirectoryIndexShell>
