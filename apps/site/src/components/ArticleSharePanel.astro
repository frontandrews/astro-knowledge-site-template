---
import { randomUUID } from 'node:crypto'
import ClipboardCopyIcon from '@lucide/astro/icons/clipboard-copy'
import MessageCircleIcon from '@lucide/astro/icons/message-circle'
import Share2Icon from '@lucide/astro/icons/share-2'

import ArticleSharePanelClient from '@/components/ArticleSharePanelClient.svelte'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { cn } from '@/lib/cn'
import { articleShareDomHooks, getDataHookAttributes, sharedDomHooks } from '@/lib/dom-hooks'
import { ui } from '@/lib/ui'

type Props = {
  description: string
  locale: SiteLocale
  title: string
  url: string
}

const { description, locale, title, url } = Astro.props
const copy = getSiteCopy(locale)
const shareText = `${title}\n\n${description}\n\n${url}`
const whatsappHref = `https://wa.me/?text=${encodeURIComponent(shareText)}`
const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`
const iconButtonClass = ui.iconButton
const controllerId = randomUUID()
---

<section
  class={cn(ui.articleSection, 'grid gap-3 px-0 py-0')}
  {...getDataHookAttributes(articleShareDomHooks.root)}
  {...getDataHookAttributes(sharedDomHooks.controllerId, controllerId)}
  {...getDataHookAttributes(articleShareDomHooks.copyLinkError, copy.article.copyLinkError)}
  {...getDataHookAttributes(articleShareDomHooks.copyLinkSuccess, copy.article.copyLinkSuccess)}
  {...getDataHookAttributes(articleShareDomHooks.description, description)}
  {...getDataHookAttributes(articleShareDomHooks.fallback, copy.article.shareFallback)}
  {...getDataHookAttributes(articleShareDomHooks.title, title)}
  {...getDataHookAttributes(articleShareDomHooks.url, url)}
>
  <div class="grid justify-items-center gap-3 py-3 text-center lg:gap-4 lg:py-4">
    <p class={ui.shareLabel}>
      {copy.article.shareTitle}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-2">
      <button
        aria-label={copy.article.share}
        class={iconButtonClass}
        {...getDataHookAttributes(articleShareDomHooks.nativeButton)}
        title={copy.article.share}
        type="button"
      >
        <Share2Icon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.article.share}</span>
      </button>
      <a
        aria-label={copy.article.shareOnTwitter}
        class={iconButtonClass}
        href={twitterHref}
        rel="noreferrer"
        target="_blank"
        title={copy.article.shareOnTwitter}
      >
        <span aria-hidden="true" class="text-[0.88rem] font-semibold tracking-[0.02em] lg:text-[0.96rem]">X</span>
        <span class="sr-only">{copy.article.shareOnTwitter}</span>
      </a>
      <a
        aria-label={copy.article.shareOnLinkedIn}
        class={iconButtonClass}
        href={linkedinHref}
        rel="noreferrer"
        target="_blank"
        title={copy.article.shareOnLinkedIn}
      >
        <span aria-hidden="true" class="text-[0.9rem] font-semibold lowercase tracking-[-0.02em] lg:text-[0.98rem]">in</span>
        <span class="sr-only">{copy.article.shareOnLinkedIn}</span>
      </a>
      <a
        aria-label={copy.article.shareOnWhatsApp}
        class={iconButtonClass}
        href={whatsappHref}
        rel="noreferrer"
        target="_blank"
        title={copy.article.shareOnWhatsApp}
      >
        <MessageCircleIcon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.article.shareOnWhatsApp}</span>
      </a>
      <button
        aria-label={copy.article.copyLink}
        class={iconButtonClass}
        {...getDataHookAttributes(articleShareDomHooks.copyButton)}
        title={copy.article.copyLink}
        type="button"
      >
        <ClipboardCopyIcon aria-hidden="true" class="size-4" />
        <span class="sr-only">{copy.article.copyLink}</span>
      </button>
    </div>
  </div>

  <p
    aria-live="polite"
    class="hidden text-center text-sm leading-6 text-site-ink-soft lg:text-[0.96rem]"
    {...getDataHookAttributes(articleShareDomHooks.feedback)}
  />

  <ArticleSharePanelClient client:idle controllerId={controllerId} />
</section>
