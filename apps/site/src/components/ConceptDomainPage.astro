---
import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { getConceptsHref } from '@/lib/concepts-links'
import {
  getConceptDomainRouteSegment,
  getLocalizedConceptDomainLabel,
  getLocalizedConceptDomainSummary,
  getLocalizedConceptGroupLabel,
  getLocalizedConceptGroupSummary,
} from '@/lib/concept-taxonomy'
import type { SiteLocale } from '@/lib/site-copy'

type GroupCard = {
  count: number
  groupId: string
  href: string
}

type Props = {
  domainId: string
  groups: GroupCard[]
  locale: SiteLocale
}

const { domainId, groups, locale } = Astro.props
const domainLabel = getLocalizedConceptDomainLabel(domainId, locale)
const domainSummary = getLocalizedConceptDomainSummary(domainId, locale)
const englishHref = getConceptsHref('en', getConceptDomainRouteSegment(domainId, 'en'))
const portugueseHref = getConceptsHref('pt-br', getConceptDomainRouteSegment(domainId, 'pt-br'))
const breadcrumbItems = [
  {
    href: getConceptsHref(locale),
    label: locale === 'pt-br' ? 'Conceitos' : 'Concepts',
  },
  {
    href: null,
    label: domainLabel,
  },
]
const items = groups.map((group) => ({
  description: getLocalizedConceptGroupSummary(domainId, group.groupId, locale),
  href: group.href,
  meta: locale === 'pt-br' ? `${group.count} conceitos` : `${group.count} concepts`,
  tags: [],
  title: getLocalizedConceptGroupLabel(domainId, group.groupId, locale),
}))
---

<BaseLayout
  description={domainSummary}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={domainLabel}
>
  <PageHeader breadcrumbs={breadcrumbItems} description={domainSummary} title={domainLabel} />

  <CompactSection>
    <FilterableDirectory
      items={items}
      kind="title-cards"
    />
  </CompactSection>
</BaseLayout>
