---
import type { CollectionEntry } from 'astro:content'
import BrainIcon from '@lucide/astro/icons/brain'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { getConceptHrefFromEntry, getConceptsHref } from '@/lib/concepts-links'
import { getLocalePath, resolveLocaleHrefMap } from '@/lib/locale-config'
import { getPageTypeDescription, getPageTypeLabel } from '@/lib/section-manifest'
import {
  CONCEPT_DOMAINS,
  getAvailableConceptGroups,
  getConceptDomainRouteSegment,
  getConceptGroupRouteSegment,
  getLocalizedConceptDomainLabel,
  getLocalizedConceptGroupLabel,
} from '@/lib/concept-taxonomy'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  concepts: CollectionEntry<'concepts'>[]
  isHome?: boolean
  locale: SiteLocale
}

const { concepts, isHome = false, locale } = Astro.props
const copy = getSiteCopy(locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  isHome ? getLocalePath(supportedLocale) : getConceptsHref(supportedLocale),
)
const title = getPageTypeLabel('concepts', locale)
const description = getPageTypeDescription('concepts', locale)
const availableDomains = CONCEPT_DOMAINS.filter((domain) =>
  concepts.some((concept) => concept.data.domainId === domain.id),
)
const availableFilters = availableDomains.flatMap((domain) => {
  const domainSegment = getConceptDomainRouteSegment(domain.id, locale)
  const groupFilters = getAvailableConceptGroups(concepts, domain.id, locale).map((group) => ({
    id: `${domainSegment}/${getConceptGroupRouteSegment(domain.id, group.id, locale)}`,
    label: getLocalizedConceptGroupLabel(domain.id, group.id, locale),
  }))

  return [
    {
      id: domainSegment,
      label: getLocalizedConceptDomainLabel(domain.id, locale),
    },
    ...groupFilters,
  ]
})
const items = concepts.map((concept) => {
  const domainSegment = getConceptDomainRouteSegment(concept.data.domainId, locale)
  const groupSegment = getConceptGroupRouteSegment(concept.data.domainId, concept.data.groupId, locale)

  return {
    href: getConceptHrefFromEntry(concept),
    tags: [
      {
        id: domainSegment,
        label: getLocalizedConceptDomainLabel(concept.data.domainId, locale),
      },
      {
        id: `${domainSegment}/${groupSegment}`,
        label: getLocalizedConceptGroupLabel(concept.data.domainId, concept.data.groupId, locale),
      },
    ],
    title: concept.data.title,
  }
})
---

<DirectoryIndexShell
  description={description}
  icon={BrainIcon}
  iconLabel={title}
  localeHrefs={localeHrefs}
  title={title}
>
  <FilterableDirectory
    allItemsLabel={copy.directory.allItems}
    availableFilters={availableFilters}
    articleItemsLabel={copy.directory.articleItems}
    filterLabel={copy.directory.filterByConcept}
    filterQueryKey="scope"
    items={items}
    client:idle
    layout="cards"
    noteItemsLabel={copy.directory.noteItems}
  />
</DirectoryIndexShell>
