---
import BaseLayout from '@/layouts/BaseLayout.astro'
import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import CompactSection from '@/components/ui/CompactSection.astro'
import PageHeader from '@/components/ui/PageHeader.astro'
import { getConceptsHref } from '@/lib/concepts-links'
import { getLocalizedConceptDomainLabel } from '@/lib/concept-taxonomy'
import type { SiteLocale } from '@/lib/site-copy'

type DomainCard = {
  count: number
  domainId: string
  href: string
}

type Props = {
  domains: DomainCard[]
  locale: SiteLocale
}

const { domains, locale } = Astro.props
const englishHref = getConceptsHref('en')
const portugueseHref = getConceptsHref('pt-br')
const copy =
  locale === 'pt-br'
    ? {
        intro: 'Conceitos tecnicos mais densos, organizados por dominio para facilitar navegacao e aprofundamento.',
        title: 'Conceitos',
      }
    : {
        intro: 'Deeper technical concepts, organized by domain so they are easier to browse and revisit.',
        title: 'Concepts',
      }
const items = domains.map((domain) => ({
  href: domain.href,
  tags: [],
  title: getLocalizedConceptDomainLabel(domain.domainId, locale),
}))
---

<BaseLayout
  description={copy.intro}
  englishHref={englishHref}
  portugueseHref={portugueseHref}
  title={copy.title}
>
  <PageHeader description={copy.intro} title={copy.title} />

  <CompactSection>
    <FilterableDirectory
      items={items}
      kind="title-cards"
    />
  </CompactSection>
</BaseLayout>
