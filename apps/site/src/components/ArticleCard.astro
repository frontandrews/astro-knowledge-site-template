---
import type { CollectionEntry } from 'astro:content'
import { getGuideHrefFromEntry } from '@/lib/guide-links'
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'
import {
  articleCardArticleVariants,
  articleCardLinkVariants,
  articleCardTitleVariants,
  eyebrowVariants,
} from '@/lib/ui-variants'
import InlineArrowCta from '@/components/ui/InlineArrowCta.astro'
import ArrowRightIcon from '@/components/ui/icons/ArrowRightIcon.astro'

type Props = {
  categoryLabel?: string
  className?: string
  eyebrow?: string
  eyebrowVariant?: 'caps' | 'sentence'
  meta?: string
  post: CollectionEntry<'guides'>
  subtitle?: string
  variant?: 'linear' | 'minimal' | 'rich'
}

const {
  categoryLabel,
  className,
  eyebrow,
  eyebrowVariant = 'caps',
  meta,
  post,
  subtitle = post.data.description,
  variant = 'minimal',
} = Astro.props
const href = getGuideHrefFromEntry(post)
const ctaLabel = post.data.locale === 'pt-br' ? 'Ler mais' : 'Learn more'
const completedCtaLabel = post.data.locale === 'pt-br' ? 'Ler novamente' : 'Read again'
---

<article
  class={cn(articleCardArticleVariants({ variant }), className)}
  data-guide-card-category={categoryLabel}
  data-guide-post={post.data.guideId}
>
  <a class={articleCardLinkVariants({ variant })} href={href}>
    <span
      aria-hidden="true"
      class="pointer-events-none absolute right-4 top-4 hidden size-8 items-center justify-center rounded-full border border-[color:color-mix(in_srgb,var(--site-success)_55%,transparent)] bg-[color:color-mix(in_srgb,var(--site-success)_20%,var(--site-surface))] text-[0.98rem] font-semibold text-[color:color-mix(in_srgb,var(--site-success)_78%,black_22%)] min-[64rem]:size-9 min-[64rem]:text-[1.08rem]"
      data-guide-post-complete-badge
    >
      ✓
    </span>
    {eyebrow ? (
      <p class={eyebrowVariants({ tone: eyebrowVariant })}>
        {eyebrow}
      </p>
    ) : null}
    <h3 class={articleCardTitleVariants({ variant })} data-card-title>
      {post.data.title}
    </h3>
    {(variant === 'linear' || variant === 'rich') && subtitle ? (
      <p class={ui.cardDescription}>{subtitle}</p>
    ) : null}
    {variant === 'linear' ? (
      <>
        <InlineArrowCta className="md:hidden" label={ctaLabel} />
        <span class="pointer-events-none absolute right-4 top-1/2 hidden min-w-[9.25rem] -translate-y-1/2 items-center justify-end md:inline-flex">
          <span
            aria-hidden="true"
            class="inline-flex size-8 items-center justify-center rounded-full border border-[color:color-mix(in_srgb,var(--site-success)_55%,transparent)] bg-[color:color-mix(in_srgb,var(--site-success)_20%,var(--site-surface))] text-[0.98rem] font-semibold text-[color:color-mix(in_srgb,var(--site-success)_78%,black_22%)] opacity-0 transition-all duration-150 min-[64rem]:size-9 min-[64rem]:text-[1.08rem]"
            data-guide-post-complete-badge
          >
            ✓
          </span>
          <span class="absolute right-0 inline-flex translate-x-1 items-center gap-1.5 text-[0.76rem] font-medium tracking-[0.04em] text-site-ink-muted opacity-0 transition-all duration-150 min-[64rem]:gap-2 min-[64rem]:text-[0.84rem]" data-guide-post-complete-text>
            <span>{completedCtaLabel}</span>
            <ArrowRightIcon className="size-[0.88rem]" />
          </span>
          <span class="absolute right-0 inline-flex translate-x-1 items-center gap-1.5 text-[0.76rem] font-medium tracking-[0.04em] text-site-ink-muted opacity-0 transition-all duration-150 group-hover:translate-x-0 group-hover:opacity-100 group-hover:text-site-link-hover group-focus-within:translate-x-0 group-focus-within:opacity-100 group-focus-within:text-site-link-hover min-[64rem]:gap-2 min-[64rem]:text-[0.84rem]" data-guide-post-default-cta>
            <span>{ctaLabel}</span>
            <ArrowRightIcon className="size-[0.88rem]" />
          </span>
        </span>
      </>
    ) : null}
    {variant === 'rich' && meta ? (
      <p class={ui.cardMetaCaps}>{meta}</p>
    ) : null}
  </a>
</article>
