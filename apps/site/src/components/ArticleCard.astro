---
import type { CollectionEntry } from 'astro:content'
import { getArticleHrefFromEntry } from '@/lib/article-links'
import { cn } from '@/lib/cn'
import { completionDomHooks, getDataHookAttributes } from '@/lib/dom-hooks'
import { getSiteCopy } from '@/lib/site-copy'
import { ui } from '@/lib/ui'
import {
  articleCardArticleVariants,
  articleCardLinkVariants,
  articleCardTitleVariants,
  eyebrowVariants,
} from '@/lib/ui-variants'
import ArrowRightIcon from '@/components/ui/icons/ArrowRightIcon.astro'

type Props = {
  categoryLabel?: string
  className?: string
  eyebrow?: string
  eyebrowVariant?: 'caps' | 'sentence'
  meta?: string
  post: CollectionEntry<'articles'>
  subtitle?: string
  variant?: 'linear' | 'minimal' | 'rich'
}

const {
  categoryLabel,
  className,
  eyebrow,
  eyebrowVariant = 'caps',
  meta,
  post,
  subtitle = post.data.description,
  variant = 'minimal',
} = Astro.props
const href = getArticleHrefFromEntry(post)
const copy = getSiteCopy(post.data.locale)
const ctaLabel = copy.directory.readMore
const completedCtaLabel = copy.directory.readAgain
---

<article
  class={cn('content-directory-item', articleCardArticleVariants({ variant }), className)}
  data-article-card-category={categoryLabel}
  {...getDataHookAttributes(completionDomHooks.item, post.data.articleId)}
>
  <a class={articleCardLinkVariants({ variant })} href={href}>
    <span
      aria-hidden="true"
      class={cn(
        'content-directory-complete-badge',
        ui.completionBadgeCard,
        variant === 'linear' && ui.completionBadgeLinear,
      )}
      {...getDataHookAttributes(completionDomHooks.completeBadge)}
    >
      ✓
    </span>
    {eyebrow ? (
      <p class={eyebrowVariants({ tone: eyebrowVariant })}>
        {eyebrow}
      </p>
    ) : null}
    <h3 class={cn('content-directory-title', articleCardTitleVariants({ variant }))} {...getDataHookAttributes(completionDomHooks.title)}>
      {post.data.title}
    </h3>
    {(variant === 'linear' || variant === 'rich') && subtitle ? (
      <p class={ui.cardDescription}>{subtitle}</p>
    ) : null}
    {variant === 'linear' ? (
      <>
        <span
          aria-hidden="true"
          class={cn('content-directory-mobile-default-cta', ui.inlineCta, 'md:hidden')}
          {...getDataHookAttributes(completionDomHooks.mobileDefaultText)}
        >
          <span>{ctaLabel}</span>
          <ArrowRightIcon className="size-[0.88rem]" />
        </span>
        <span
          aria-hidden="true"
          class={cn('content-directory-mobile-complete-text', ui.inlineCta, 'hidden md:hidden')}
          {...getDataHookAttributes(completionDomHooks.mobileCompleteText)}
        >
          <span>{completedCtaLabel}</span>
          <ArrowRightIcon className="size-[0.88rem]" />
        </span>
        <span class={ui.completionRailMd}>
          <span
            aria-hidden="true"
            class={cn('content-directory-complete-text', ui.completionDesktopCta)}
            {...getDataHookAttributes(completionDomHooks.completeText)}
          >
            <span>{completedCtaLabel}</span>
            <ArrowRightIcon className="size-[0.88rem]" />
          </span>
          <span
            aria-hidden="true"
            class={cn('content-directory-default-cta', ui.completionDesktopCtaInteractive)}
            {...getDataHookAttributes(completionDomHooks.defaultText)}
          >
            <span>{ctaLabel}</span>
            <ArrowRightIcon className="size-[0.88rem]" />
          </span>
        </span>
      </>
    ) : null}
    {variant === 'rich' && meta ? (
      <p class={ui.cardMetaCaps}>{meta}</p>
    ) : null}
  </a>
</article>
