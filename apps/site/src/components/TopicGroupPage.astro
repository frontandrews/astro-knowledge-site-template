---
import DirectoryList from '@/components/ui/DirectoryList.astro'
import DirectoryPagination from '@/components/ui/DirectoryPagination.astro'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import {
  TOPIC_GROUP_DIRECTORY_PAGE_SIZE,
  buildArticleDirectoryItems,
  paginateItems,
} from '@/lib/directory'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getActiveArticlesByLocale } from '@/lib/site-content'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { getTopicGroupHref, getTopicGroupPageHref, getTopicHref, getTopicPageHref } from '@/lib/topic-links'
import {
  getLocalizedTopicLabel,
  getLocalizedTopicSummary,
  getTopicBreadcrumb,
  getLocalizedTopicGroupLabel,
  getLocalizedTopicGroupSummary,
  getTopicGroupArticles,
  getTopicGroupBreadcrumb,
  getTopicTreeArticles,
} from '@/lib/topic-taxonomy'
import type { CollectionEntry } from 'astro:content'

type Props = {
  groupId: string
  locale: SiteLocale
  page?: number
  posts?: CollectionEntry<'articles'>[]
  topicId?: string | null
}

const { groupId, locale, page = 1, posts = [], topicId = null } = Astro.props
const copy = getSiteCopy(locale)
const title = topicId ? getLocalizedTopicLabel(topicId, locale) : getLocalizedTopicGroupLabel(groupId, locale)
const description = topicId ? getLocalizedTopicSummary(topicId, locale) : getLocalizedTopicGroupSummary(groupId, locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) =>
  topicId ? getTopicHref(topicId, supportedLocale) : getTopicGroupHref(groupId, supportedLocale),
)
const allPosts = posts.length > 0 ? posts : await getActiveArticlesByLocale(locale)
const sourcePosts = topicId ? getTopicTreeArticles(allPosts, topicId, locale) : getTopicGroupArticles(allPosts, groupId, locale)
const items = buildArticleDirectoryItems(sourcePosts, locale, { groupId })
const paginatedItems = paginateItems(items, page, TOPIC_GROUP_DIRECTORY_PAGE_SIZE)
const pageTitle = page > 1 ? `${title} · ${copy.directory.page} ${paginatedItems.currentPage}` : title
const isPaginatedArchivePage = paginatedItems.currentPage > 1
---

<DirectoryIndexShell
  breadcrumbs={topicId ? getTopicBreadcrumb(topicId, locale) : getTopicGroupBreadcrumb(groupId, locale)}
  description={description}
  localeHrefs={localeHrefs}
  noindex={isPaginatedArchivePage}
  pagefind={!isPaginatedArchivePage}
  title={pageTitle}
>
  {paginatedItems.items.length > 0 ? (
    <DirectoryList items={paginatedItems.items} layout="rows" />
  ) : (
    <p class="m-0 text-base leading-7 text-site-ink-soft">{copy.articlesIndex.comingSoon}</p>
  )}

  <DirectoryPagination
    currentPage={paginatedItems.currentPage}
    getHref={(targetPage) => (topicId ? getTopicPageHref(topicId, locale, targetPage) : getTopicGroupPageHref(groupId, locale, targetPage))}
    nextLabel={copy.directory.nextPage}
    pageCount={paginatedItems.pageCount}
    pageLabel={copy.directory.page}
    previousLabel={copy.directory.previousPage}
  />
</DirectoryIndexShell>
