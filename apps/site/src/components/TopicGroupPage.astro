---
import { getTopicRouteSegment, type TopicDefinition } from '@template/content'

import FilterableDirectory from '@/components/FilterableDirectory.svelte'
import DirectoryIndexShell from '@/components/ui/DirectoryIndexShell.astro'
import { getArticleHrefFromEntry } from '@/lib/article-links'
import { formatEditorialDate } from '@/lib/format-date'
import { resolveLocaleHrefMap } from '@/lib/locale-config'
import { getTopicGroupHref } from '@/lib/topic-links'
import {
  getLocalizedTopicGroupLabel,
  getLocalizedTopicGroupSummary,
  getLocalizedTopicLabel,
  getLocalizedArticleTopicsInGroup,
  getTopicGroupBreadcrumb,
} from '@/lib/topic-taxonomy'
import type { CollectionEntry } from 'astro:content'
import { siteStorageKeys } from '@/lib/storage-keys'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'

type Props = {
  groupId: string
  locale: SiteLocale
  posts: CollectionEntry<'articles'>[]
  topics: TopicDefinition[]
}

const { groupId, locale, posts, topics } = Astro.props
const copy = getSiteCopy(locale)
const title = getLocalizedTopicGroupLabel(groupId, locale)
const description = getLocalizedTopicGroupSummary(groupId, locale)
const localeHrefs = resolveLocaleHrefMap((supportedLocale) => getTopicGroupHref(groupId, supportedLocale))
const dateLocale = locale === 'pt-br' ? 'pt-BR' : 'en-US'
const filterItems = topics.map((topic) => ({
  id: getTopicRouteSegment(topic.id, locale),
  label: getLocalizedTopicLabel(topic.id, locale),
}))
const items = posts.map((post) => ({
  badgeLabel: post.data.kind === 'note' ? copy.directory.noteBadge : undefined,
  completedCtaLabel: copy.directory.readAgain,
  completionId: post.data.articleId,
  contentKind: post.data.kind,
  ctaLabel: copy.directory.readMore,
  description: post.data.description,
  eyebrow: formatEditorialDate(post.data.pubDate, dateLocale),
  href: getArticleHrefFromEntry(post),
  tags: getLocalizedArticleTopicsInGroup(post, groupId, locale).map(({ id, label }) => ({ id, label })),
  title: post.data.title,
}))
---

<DirectoryIndexShell
  breadcrumbs={getTopicGroupBreadcrumb(groupId, locale)}
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <FilterableDirectory
    allItemsLabel={copy.directory.allItems}
    articleItemsLabel={copy.directory.articleItems}
    availableFilters={filterItems}
    completionStorageKey={siteStorageKeys.completedArticles}
    filterLabel={copy.directory.filterBySubtopic}
    filterQueryKey="sub"
    fewerFiltersLabel={copy.directory.showLess}
    items={items}
    client:load
    layout="rows"
    moreFiltersLabel={copy.directory.more}
    noteItemsLabel={copy.directory.noteItems}
  />
</DirectoryIndexShell>
