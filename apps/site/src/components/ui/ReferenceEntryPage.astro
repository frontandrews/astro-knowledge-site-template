---
import ArticleSharePanel from '@/components/ArticleSharePanel.astro'
import AuthorByline from '@/components/ui/AuthorByline.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import ContentArticleHeader from '@/components/ui/ContentArticleHeader.astro'
import { cn } from '@/lib/cn'
import { getSiteCopy, type SiteLocale } from '@/lib/site-copy'
import { ui } from '@/lib/ui'

type Props = {
  alternateLocaleHrefs?: Record<string, string | null>
  createdMeta: string | null
  description: string
  locale: SiteLocale
  localeHrefs?: Record<string, string | null>
  title: string
  updatedMeta?: string | null
  url: string
}

const {
  alternateLocaleHrefs = {},
  createdMeta,
  description,
  locale,
  localeHrefs = {},
  title,
  updatedMeta = null,
  url,
} = Astro.props
const copy = getSiteCopy(locale)

---

<BaseLayout
  alternateLocaleHrefs={alternateLocaleHrefs}
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <article class="w-full pb-11">
    <ContentArticleHeader
      createdMeta={createdMeta}
      description={description}
      title={title}
    >
      <AuthorByline />
      {updatedMeta ? (
        <p class={cn(ui.articleMetaSubtle, 'mt-3')}>
          {copy.article.updatedPrefix} {updatedMeta}
        </p>
      ) : null}
      <slot name="headerMeta" />
    </ContentArticleHeader>

    <div class={ui.articleRail}>
      <div class="min-w-0">
        <div class="article-prose">
          <slot />
        </div>

        <ArticleSharePanel
          description={description}
          locale={locale}
          title={title}
          url={url}
        />

        <slot name="afterContent" />
      </div>
    </div>
  </article>
</BaseLayout>
