---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { cn } from '@/lib/cn'
import { ui } from '@/lib/ui'

type BreadcrumbItem = {
  href: string | null
  label: string
}

type Props = {
  breadcrumbs?: BreadcrumbItem[]
  className?: string
  description: string
  icon?: any
  iconLabel?: string
  sectionClass?: string
  title: string
}

const {
  breadcrumbs = [],
  className = '',
  description,
  icon: Icon = null,
  iconLabel = '',
  sectionClass = ui.compactSection,
  title,
} = Astro.props
const pageHeaderTitleClass =
  'm-0 font-sans text-[clamp(1.35rem,4vw,1.9rem)] font-semibold tracking-[-0.035em] text-site-link-hover lg:text-[clamp(1.5rem,2.5vw,2.1rem)]'
const pageHeaderDescriptionClass = cn(ui.bodyCopy, 'mt-0')
---

<section class={sectionClass}>
  <div class={cn(ui.toolbar, className)}>
    {breadcrumbs.length > 0 ? <Breadcrumbs items={breadcrumbs} /> : null}
    {Icon ? (
      <div class="flex items-stretch gap-3 lg:gap-4">
        <span
          aria-label={iconLabel || title}
          class="inline-flex h-full w-24 shrink-0 items-center justify-center self-stretch text-site-link-hover lg:w-28"
        >
          <Icon class="block h-full w-full max-w-none" stroke-width="0.75" />
        </span>
        <div class="min-w-0 flex flex-1 flex-col justify-center gap-0">
          <h1 class={pageHeaderTitleClass}>{title}</h1>
          <p class={pageHeaderDescriptionClass}>{description}</p>
          <slot />
        </div>
      </div>
    ) : (
      <div class={cn(ui.toolbarIntro, 'gap-0 space-y-0')}>
        <h1 class={pageHeaderTitleClass}>{title}</h1>
        <p class={pageHeaderDescriptionClass}>{description}</p>
        <slot />
      </div>
    )}
  </div>
</section>
