---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { ui } from '@/lib/ui'
import '@/styles/article-prose.css'

type Props = {
  description: string
  kicker?: string
  localeHrefs?: Record<string, string | null>
  title: string
}

const {
  description,
  kicker,
  localeHrefs = {},
  title,
} = Astro.props
---

<BaseLayout
  description={description}
  localeHrefs={localeHrefs}
  title={title}
>
  <section class={ui.section}>
    <article class={ui.articleShell}>
      <header class={ui.articleHeader}>
        {kicker ? <p class={ui.articleKicker}>{kicker}</p> : null}
        <h1 class={ui.articleTitle}>{title}</h1>
        <p class={ui.articleExcerpt}>{description}</p>
      </header>

      <div class="article-prose">
        <slot />
      </div>
    </article>
  </section>
</BaseLayout>
