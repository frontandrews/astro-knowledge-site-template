{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "minLength": 1
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "relatedDeckIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "description",
    "pubDate",
    "summary",
    "title"
  ]
}